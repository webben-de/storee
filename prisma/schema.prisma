generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  locations      Location[]
  objects        StoreeObject[]
  objectHistories ObjectHistory[]

  @@map("users")
}

model Location {
  id          String   @id
  userId      String   @map("user_id")
  parentId    String?  @map("parent_id")
  name        String
  description String   @default("")
  icon        String   @default("📁")
  gpsLat      Float?   @map("gps_lat")
  gpsLng      Float?   @map("gps_lng")
  imageUri    String?  @map("image_uri")
  sortOrder   BigInt   @map("sort_order")
  createdAt   BigInt   @map("created_at")
  updatedAt   BigInt   @map("updated_at")
  deletedAt   BigInt?  @map("deleted_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Location? @relation("LocationChildren", fields: [parentId], references: [id])
  children Location[] @relation("LocationChildren")
  objects  StoreeObject[]

  @@index([userId])
  @@index([parentId])
  @@map("locations")
}

model StoreeObject {
  id          String   @id
  userId      String   @map("user_id")
  locationId  String   @map("location_id")
  name        String
  description String   @default("")
  category    String   @default("")
  tags        String[] @default([])
  imageUri    String?  @map("image_uri")
  gpsLat      Float?   @map("gps_lat")
  gpsLng      Float?   @map("gps_lng")
  quantity    Int      @default(1)
  createdAt   BigInt   @map("created_at")
  updatedAt   BigInt   @map("updated_at")
  deletedAt   BigInt?  @map("deleted_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  history  ObjectHistory[]

  @@index([userId])
  @@index([locationId])
  @@map("objects")
}

model ObjectHistory {
  id             String  @id
  userId         String  @map("user_id")
  objectId       String  @map("object_id")
  fromLocationId String? @map("from_location_id")
  toLocationId   String  @map("to_location_id")
  movedAt        BigInt  @map("moved_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  object StoreeObject @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@map("object_history")
}
